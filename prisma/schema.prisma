// Prisma schema for Rossy Resina

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  CUSTOMER
}

enum SubscriberStatus {
  ACTIVO
  DESACTIVADO
}

enum CreationType {
  FOTO
  VIDEO
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  subscriber   SubscriberProfile?
  orders       Order[]
  reviews      Review[]
}

model SubscriberProfile {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id])
  displayName String
  handle      String           @unique
  avatar      String
  bio         String
  status      SubscriberStatus @default(ACTIVO)
  location    String
  joined      DateTime         @default(now())
  creations   Creation[]
}

model Creation {
  id         String       @id @default(cuid())
  profileId  String
  profile    SubscriberProfile @relation(fields: [profileId], references: [id])
  type       CreationType
  title      String
  cover      String
  createdAt  DateTime     @default(now())
}

model Product {
  id          String   @id @default(cuid())
  legacyId    String?  @unique
  code        String?  @unique
  barcode     String?
  sku         String?
  title       String
  description String
  brand       String
  category    String
  image       String
  images      Json?
  price       Decimal  @db.Decimal(10, 2)
  oldPrice    Decimal? @db.Decimal(10, 2)
  isNew       Boolean  @default(false)
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reviews     Review[]
  variants    ProductVariant[]
}

model Order {
  id             String      @id @default(cuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  status         OrderStatus @default(PENDING)
  total          Decimal     @db.Decimal(10, 2)
  items          Json
  customerName   String
  customerEmail  String
  customerPhone  String
  customerAddress String
  customerCity   String
  customerDistrict String
  customerNotes  String?
  paymentImage   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([customerEmail])
  @@index([status])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String   // ej: "1kg", "2kg", "Galón (4kg)"
  price     Decimal  @db.Decimal(10, 2)
  oldPrice  Decimal? @db.Decimal(10, 2)
  stock     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
}

model WebVisitEvent {
  id        String   @id @default(cuid())
  visitedAt DateTime @default(now())
  path      String
  country   String   @default("DESCONOCIDO")
  city      String   @default("DESCONIDA")
  visitorId String
  userEmail String?
  userName  String?

  visitor WebVisitorProfile? @relation(fields: [visitorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([visitedAt])
  @@index([path])
  @@index([country])
  @@index([city])
  @@index([visitorId])
  @@index([userEmail])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebVisitorProfile {
  id         String   @id
  firstSeenAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  visitCount Int      @default(0)
  userEmail  String?
  userName   String?
  country    String   @default("DESCONOCIDO")
  city       String   @default("DESCONOCIDA")
  lastPath   String?

  events WebVisitEvent[]

  @@index([lastSeenAt])
  @@index([visitCount])
  @@index([country])
  @@index([city])
  @@index([userEmail])
}

model VisitExcludedIp {
  ip        String   @id
  note      String?
  createdAt DateTime @default(now())
}

// Curso/taller creado por Rossy con múltiples fechas disponibles
model Curso {
  id             String       @id @default(cuid())
  nombre         String
  nivel          String       @default("Basico")
  descripcion    String       @default("")
  modalidad      String       @default("Presencial")
  ciudad         String       @default("")
  sede           String       @default("")
  duracionHoras  Int          @default(2)
  precio         Decimal      @db.Decimal(10, 2)
  precioAnterior Decimal?     @db.Decimal(10, 2)
  cupoMax        Int          @default(6)
  imagen         String       @default("")
  notaAdmin      String       @default("")
  createdAt      DateTime     @default(now())
  fechas         CursoFecha[]
}

// Fecha disponible de un curso (hora siempre 16:00 PE)
model CursoFecha {
  id            String             @id @default(cuid())
  cursoId       String
  curso         Curso              @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  fecha         DateTime
  createdAt     DateTime           @default(now())
  inscripciones TallerInscripcion[]

  @@index([cursoId])
  @@index([fecha])
}

// Inscripción de una cliente a una fecha de curso
model TallerInscripcion {
  id          String     @id @default(cuid())
  fechaId     String
  cursoFecha  CursoFecha @relation(fields: [fechaId], references: [id], onDelete: Cascade)
  nombre      String
  email       String
  telefono    String
  notas       String     @default("")
  createdAt   DateTime   @default(now())

  @@index([fechaId])
  @@index([email])
}

model OfertaExpress {
  id        String   @id @default(cuid())
  nombre    String
  imagen    String
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  author    String   @default("Rossy")
  date      String
  excerpt   String   @default("")
  content   Json     @default("[]")
  image     String   @default("")
  comments  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model NewsletterSubscriber {
  email     String   @id
  createdAt DateTime @default(now())
}

model CustomerProfile {
  dni             String   @id
  name            String
  phone           String
  locationLine    String
  shippingCarrier String   @default("SHALOM")
  shalomAgency    String   @default("")
  olvaAddress     String   @default("")
  olvaReference   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CapacitacionInscripcion {
  id              String    @id @default(cuid())
  nombre          String
  email           String
  telefono        String    @default("")
  curso           String
  nivel           String    @default("Basico")
  mensaje         String    @default("")
  estado          String    @default("PENDIENTE")
  fechaProgramada DateTime?
  notaAdmin       String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([estado])
}
